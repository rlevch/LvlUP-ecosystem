# =============================================================================
# SCORE Coaching Platform — Environment Variables
# =============================================================================
# Скопируй этот файл: cp .env.example .env
# Заполни ВСЕ переменные со значением CHANGE_ME
# =============================================================================

# ---------------------------------------------------------------------------
# Домен и URL-ы
# ---------------------------------------------------------------------------
DOMAIN=score-coaching.ru
SITE_URL=https://score-coaching.ru
API_EXTERNAL_URL=https://api.score-coaching.ru

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_1
# ВАЖНО: используй "postgres" — supabase/postgres образ создаёт auth/storage/realtime схемы именно в этой БД
POSTGRES_DB=postgres

# ---------------------------------------------------------------------------
# JWT (Supabase GoTrue)
# Сгенерировать: openssl rand -base64 64 | tr -d '\n'
# ---------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXP=3600

# ---------------------------------------------------------------------------
# Supabase Keys
# Сгенерировать через: https://supabase.com/docs/guides/self-hosting#api-keys
# Или скриптом: node infrastructure/scripts/generate-keys.js
# ---------------------------------------------------------------------------
ANON_KEY=CHANGE_ME_GENERATE_ANON_KEY
SERVICE_ROLE_KEY=CHANGE_ME_GENERATE_SERVICE_ROLE_KEY

# ---------------------------------------------------------------------------
# Supabase Realtime
# Сгенерировать: openssl rand -base64 48 | tr -d '\n'
# ---------------------------------------------------------------------------
REALTIME_ENC_KEY=CHANGE_ME_REALTIME_ENC_KEY
REALTIME_SECRET_KEY_BASE=CHANGE_ME_REALTIME_SECRET_BASE_MIN_64_CHARS_AAAAAAAAAAAAAAAAAAAAAAAAA

# ---------------------------------------------------------------------------
# MinIO (S3-совместимое хранилище)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=scoreadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD_2

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_3

# ---------------------------------------------------------------------------
# SMTP (для email-подтверждений, восстановления пароля)
# Unisender / SendPulse / MailGun с RU-доменом
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.unisender.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_ADMIN_EMAIL=noreply@score-coaching.ru

# ---------------------------------------------------------------------------
# VK ID OAuth (опционально на старте)
# Получить: https://id.vk.com/about/business/go
# ---------------------------------------------------------------------------
VK_AUTH_ENABLED=false
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=https://score-coaching.ru/auth/callback/vk

# Дополнительные redirect URL-ы для GoTrue (через запятую)
ADDITIONAL_REDIRECT_URLS=

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_STRONG_PASSWORD_4
GRAFANA_ROOT_URL=https://monitoring.score-coaching.ru

# ---------------------------------------------------------------------------
# LiveKit (VPS #2, подключается позже)
# ---------------------------------------------------------------------------
# LIVEKIT_URL=wss://media.score-coaching.ru
# LIVEKIT_API_KEY=CHANGE_ME
# LIVEKIT_API_SECRET=CHANGE_ME
